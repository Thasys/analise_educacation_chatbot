{
  "name": "edu-frontend",
  "version": "0.1.0",
  "private": true,
  "description": "Frontend Next.js 14 — interface de análise educacional comparada Brasil × Internacional",
  "scripts": {
    "dev": "next dev -p 3000 -H 0.0.0.0",
    "build": "next build",
    "start": "next start -p 3000 -H 0.0.0.0",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "gen:api-types": "openapi-typescript http://localhost:8000/openapi.json -o ./types/api.ts",
    "gen:api-types:snapshot": "openapi-typescript ./types/openapi.snapshot.json -o ./types/api.ts"
  },
  "dependencies": {
    "next": "14.2.5",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "@tanstack/react-query": "^5.51.1",
    "zustand": "^4.5.4",
    "clsx": "^2.1.1",
    "class-variance-authority": "^0.7.0",
    "tailwind-merge": "^2.4.0",
    "tailwindcss-animate": "^1.0.7",
    "lucide-react": "^0.408.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-scroll-area": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.1.2",
    "@radix-ui/react-collapsible": "^1.1.0",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0",
    "plotly.js-basic-dist-min": "^2.34.0",
    "react-plotly.js": "^2.6.0"
  },
  "devDependencies": {
    "@types/node": "20.14.9",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "eslint": "8.57.0",
    "eslint-config-next": "14.2.5",
    "typescript": "5.5.3",
    "tailwindcss": "^3.4.6",
    "postcss": "^8.4.39",
    "autoprefixer": "^10.4.19",
    "openapi-typescript": "^7.0.2",
    "prettier": "^3.3.2",
    "prettier-plugin-tailwindcss": "^0.6.5",
    "vite": "^5.4.0",
    "vitest": "^2.0.2",
    "@vitejs/plugin-react": "^4.3.1",
    "@testing-library/react": "^16.0.0",
    "@testing-library/jest-dom": "^6.4.6",
    "happy-dom": "^14.12.3",
    "@types/react-plotly.js": "^2.6.3",
    "@playwright/test": "^1.46.0"
  }
}
