# =============================================================================
# Análise Educacional Comparada — Template de variáveis de ambiente
# =============================================================================
# Copie este arquivo para `.env` (no mesmo diretório) e ajuste os valores:
#
#     cp .env.example .env
#
# O `.env` é lido automaticamente por:
#   - docker compose       (interpolação ${VAR})
#   - Pydantic Settings    (data_pipeline, api, agents)
#   - dbt                  (env_var('DUCKDB_PATH'))
#   - Next.js              (vars com prefixo NEXT_PUBLIC_)
#
# IMPORTANTE: o `.env` está no .gitignore — NUNCA o commite.
# =============================================================================


# -----------------------------------------------------------------------------
# Projeto / runtime
# -----------------------------------------------------------------------------
ENVIRONMENT=development              # development | staging | production
LOG_LEVEL=INFO                       # DEBUG | INFO | WARNING | ERROR
TZ=America/Sao_Paulo


# -----------------------------------------------------------------------------
# PostgreSQL (metadados da aplicação + backend do Prefect)
# -----------------------------------------------------------------------------
# Senha padrão é placeholder — TROQUE antes de subir os containers.
POSTGRES_USER=educacao
POSTGRES_PASSWORD=troque_esta_senha          # gere uma senha forte antes do `docker compose up`
POSTGRES_DB=educacao_metadata
POSTGRES_PREFECT_DB=prefect

# Host/porta usados quando rodando FORA do docker-compose (ex.: pytest local).
# Dentro dos containers, o host é resolvido como `postgres` automaticamente.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Override opcional da connection string completa.
# Se vazio, a URL é montada a partir dos campos acima.
# DATABASE_URL=postgresql+psycopg://educacao:troque_esta_senha@localhost:5432/educacao_metadata


# -----------------------------------------------------------------------------
# Adminer (UI web para inspecionar Postgres em http://localhost:8080)
# -----------------------------------------------------------------------------
ADMINER_DEFAULT_SERVER=postgres


# -----------------------------------------------------------------------------
# Prefect (orquestração — UI em http://localhost:4200)
# -----------------------------------------------------------------------------
PREFECT_UI_URL=http://localhost:4200
# PREFECT_API_URL=http://localhost:4200/api   # descomente para client local


# -----------------------------------------------------------------------------
# FastAPI gateway (http://localhost:8000)
# -----------------------------------------------------------------------------
# Lista separada por vírgulas. Inclua todos os origins do frontend.
API_CORS_ORIGINS=http://localhost:3000


# -----------------------------------------------------------------------------
# DuckDB (motor analítico — usado por dbt e pela API a partir da Fase 4)
# -----------------------------------------------------------------------------
# Dentro dos containers o data lake é montado em /data. Fora, use ./data.
DUCKDB_PATH=./data/duckdb/education.duckdb

# Raiz do data lake (Bronze/Silver/Gold). Em container: /data
DATA_ROOT=./data


# -----------------------------------------------------------------------------
# Frontend Next.js (http://localhost:3000)
# -----------------------------------------------------------------------------
# Vars com prefixo NEXT_PUBLIC_ são expostas ao código no browser.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000


# -----------------------------------------------------------------------------
# APIs externas (defaults oficiais — só sobrescreva para mocks/proxies)
# -----------------------------------------------------------------------------
IBGE_SIDRA_API_BASE=https://apisidra.ibge.gov.br
WORLDBANK_API_BASE=https://api.worldbank.org/v2
# stats.oecd.org foi descontinuado em 01/07/2024 — use sdmx.oecd.org.
OECD_SDMX_BASE=https://sdmx.oecd.org/public/rest
# IPEADATA expõe OData v4 sem TLS no domínio oficial (legado).
IPEA_ODATA_API_BASE=http://www.ipeadata.gov.br/api/odata4
# UNESCO UIS — Bulk Data Download Service (SDMX-JSON 2.0)
UNESCO_UIS_API_BASE=https://api.uis.unesco.org/sdmx
# Eurostat — Statistics Dissemination API (JSON-stat 2.0)
EUROSTAT_API_BASE=https://ec.europa.eu/eurostat/api/dissemination/statistics/1.0
# CEPALSTAT — base estatística da CEPAL/ECLAC para América Latina
CEPALSTAT_API_BASE=https://statistics.cepal.org/portal/cepalstat/api/v1


# -----------------------------------------------------------------------------
# Limites de rede (coletores)
# -----------------------------------------------------------------------------
HTTP_TIMEOUT_SECONDS=120
HTTP_RETRIES=3


# -----------------------------------------------------------------------------
# LLM — Anthropic (necessário a partir da Fase 5: agentes CrewAI)
# -----------------------------------------------------------------------------
# Obtenha a chave em https://console.anthropic.com/settings/keys
# Pode ficar vazia até iniciar a Fase 5.
ANTHROPIC_API_KEY=
